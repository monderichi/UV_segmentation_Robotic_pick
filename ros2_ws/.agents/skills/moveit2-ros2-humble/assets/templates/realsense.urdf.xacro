<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  
  <xacro:macro name="realsense_d435" params="parent prefix *origin">
    
    <!-- Camera Link -->
    <joint name="${prefix}_camera_joint" type="fixed">
      <xacro:insert_block name="origin"/>
      <parent link="${parent}"/>
      <child link="${prefix}_camera_link"/>
    </joint>
    
    <link name="${prefix}_camera_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.090 0.025 0.025"/>
        </geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.090 0.025 0.025"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.072"/>
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
      </inertial>
    </link>
    
    <!-- Color Frame -->
    <link name="${prefix}_camera_color_frame"/>
    <joint name="${prefix}_camera_color_joint" type="fixed">
      <parent link="${prefix}_camera_link"/>
      <child link="${prefix}_camera_color_frame"/>
      <origin xyz="0.0 0.0175 0.0" rpy="0 0 0"/>
    </joint>
    
    <!-- Color Optical Frame -->
    <link name="${prefix}_camera_color_optical_frame"/>
    <joint name="${prefix}_camera_color_optical_joint" type="fixed">
      <parent link="${prefix}_camera_color_frame"/>
      <child link="${prefix}_camera_color_optical_frame"/>
      <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
    </joint>
    
    <!-- Depth Frame -->
    <link name="${prefix}_camera_depth_frame"/>
    <joint name="${prefix}_camera_depth_joint" type="fixed">
      <parent link="${prefix}_camera_link"/>
      <child link="${prefix}_camera_depth_frame"/>
      <origin xyz="0.0 -0.0175 0.0" rpy="0 0 0"/>
    </joint>
    
    <!-- Depth Optical Frame -->
    <link name="${prefix}_camera_depth_optical_frame"/>
    <joint name="${prefix}_camera_depth_optical_joint" type="fixed">
      <parent link="${prefix}_camera_depth_frame"/>
      <child link="${prefix}_camera_depth_optical_frame"/>
      <origin xyz="0 0 0" rpy="-1.5708 0 -1.5708"/>
    </joint>
    
    <!-- Gazebo Sim Sensors -->
    <gazebo reference="${prefix}_camera_color_frame">
      <sensor name="${prefix}_color_camera" type="camera">
        <camera>
          <horizontal_fov>1.21126</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
            <format>R8G8B8</format>
          </image>
          <clip>
            <near>0.1</near>
            <far>10.0</far>
          </clip>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.007</stddev>
          </noise>
        </camera>
        <always_on>1</always_on>
        <update_rate>30</update_rate>
        <visualize>true</visualize>
        <topic>${prefix}/camera/color/image_raw</topic>
      </sensor>
    </gazebo>
    
    <gazebo reference="${prefix}_camera_depth_frame">
      <sensor name="${prefix}_depth_camera" type="depth_camera">
        <camera>
          <horizontal_fov>1.21126</horizontal_fov>
          <image>
            <width>640</width>
            <height>480</height>
          </image>
          <clip>
            <near>0.1</near>
            <far>10.0</far>
          </clip>
        </camera>
        <always_on>1</always_on>
        <update_rate>30</update_rate>
        <visualize>true</visualize>
        <topic>${prefix}/camera/depth/image_rect_raw</topic>
      </sensor>
    </gazebo>
    
  </xacro:macro>
  
</robot>
