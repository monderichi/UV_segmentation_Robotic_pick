<?xml version="1.0"?>
<!--
  UR-Compatible myCobot 320 M5 Description
  
  This file creates a single kinematic chain with UR-standard naming convention
  to ensure compatibility with existing UR10e C++ scripts and MoveIt configs.
  
  Joint names (UR standard):
    - shoulder_pan_joint
    - shoulder_lift_joint  
    - elbow_joint
    - wrist_1_joint
    - wrist_2_joint
    - wrist_3_joint
  
  Link names (UR standard):
    - base_link
    - shoulder_link
    - upper_arm_link
    - forearm_link
    - wrist_1_link
    - wrist_2_link
    - wrist_3_link
    - flange
    - tool0
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="mycobot_320">

    <xacro:property name="joint_effort" value="1000.0"/>
    <xacro:property name="joint_velocity" value="2.792527"/>
    <xacro:property name="joint_damping" value="0.0"/>
    <xacro:property name="joint_friction" value="0.0"/>

    <!-- Link masses (estimated for Gazebo simulation) -->
    <xacro:property name="base_mass" value="0.5"/>
    <xacro:property name="link1_mass" value="0.25"/>
    <xacro:property name="link2_mass" value="0.35"/>
    <xacro:property name="link3_mass" value="0.30"/>
    <xacro:property name="link4_mass" value="0.25"/>
    <xacro:property name="link5_mass" value="0.20"/>
    <xacro:property name="link6_mass" value="0.15"/>

    <xacro:macro name="link_inertial" params="mass ixx iyy izz">
      <inertial>
        <origin xyz="0 0 0.0" rpy="0 0 0"/>
        <mass value="${mass}"/>
        <inertia
          ixx="${ixx}" ixy="0.0" ixz="0.0"
          iyy="${iyy}" iyz="0.0"
          izz="${izz}"/>
      </inertial>
    </xacro:macro>

    <!-- Arguments -->
    <xacro:arg name="robot_name" default="mycobot_320"/>
    <xacro:arg name="add_world" default="true"/>
    <xacro:arg name="prefix" default=""/>
    <xacro:arg name="use_gazebo" default="false"/>
    <xacro:arg name="use_gripper" default="false"/>
    <xacro:arg name="use_soft_ee" default="true"/>
    <xacro:arg name="controllers_file" default="none"/>

    <!-- World link -->
    <xacro:if value="$(arg add_world)">
      <link name="world"/>
      <joint name="$(arg prefix)base_joint" type="fixed">
          <parent link="world"/>
          <child link="$(arg prefix)base_link"/>
          <origin xyz="0 0 0" rpy="0 0 0"/>
      </joint>
    </xacro:if>

    <!-- ============================================================ -->
    <!-- LINKS - Using UR-standard names -->
    <!-- ============================================================ -->

    <!-- base_link -->
    <link name="$(arg prefix)base_link">
      <xacro:link_inertial mass="${base_mass}" ixx="0.001" iyy="0.001" izz="0.002"/>
      <visual>
        <geometry>
          <mesh filename="package://mycobot_description/meshes/mycobot_320/base.dae"/>
        </geometry>
        <origin xyz="0.0 0 0" rpy="0 0 1.5708"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://mycobot_description/meshes/mycobot_320/base.dae"/>
        </geometry>
        <origin xyz="0.0 0 0" rpy="0 0 1.5708"/>
      </collision>
    </link>

    <!-- shoulder_link (link1) -->
    <link name="$(arg prefix)shoulder_link">
      <xacro:link_inertial mass="${link1_mass}" ixx="0.00025" iyy="0.00025" izz="0.00015"/>
      <visual>
        <geometry>
          <mesh filename="package://mycobot_description/meshes/mycobot_320/link1.dae"/>
        </geometry>
        <origin xyz="0.0 0.0 -0.078" rpy="0 0 1.5708"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://mycobot_description/meshes/mycobot_320/link1.dae"/>
        </geometry>
        <origin xyz="0.0 0.0 -0.078" rpy="0 0 1.5708"/>
      </collision>
    </link>

    <!-- upper_arm_link (link2) -->
    <link name="$(arg prefix)upper_arm_link">
      <xacro:link_inertial mass="${link2_mass}" ixx="0.00030" iyy="0.00030" izz="0.00015"/>
      <visual>
        <geometry>
          <mesh filename="package://mycobot_description/meshes/mycobot_320/link2.dae"/>
        </geometry>
        <origin xyz="0.0 0.0 -0.04" rpy="0 1.5708 0"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://mycobot_description/meshes/mycobot_320/link2.dae"/>
        </geometry>
        <origin xyz="0.0 0.0 -0.04" rpy="0 1.5708 0"/>
      </collision>
    </link>

    <!-- forearm_link (link3) -->
    <link name="$(arg prefix)forearm_link">
      <xacro:link_inertial mass="${link3_mass}" ixx="0.00025" iyy="0.00025" izz="0.00015"/>
      <visual>
        <geometry>
          <mesh filename="package://mycobot_description/meshes/mycobot_320/link3.dae"/>
        </geometry>
        <origin xyz="0.0 0.0 0.039" rpy="1.5708 1.5708 1.5708"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://mycobot_description/meshes/mycobot_320/link3.dae"/>
        </geometry>
        <origin xyz="0.0 0.0 0.039" rpy="1.5708 1.5708 1.5708"/>
      </collision>
    </link>

    <!-- wrist_1_link (link4) -->
    <link name="$(arg prefix)wrist_1_link">
      <xacro:link_inertial mass="${link4_mass}" ixx="0.00020" iyy="0.00020" izz="0.00015"/>
      <visual>
        <geometry>
          <mesh filename="package://mycobot_description/meshes/mycobot_320/link4.dae"/>
        </geometry>
        <origin xyz="0.0 -0.0024 -0.05" rpy="1.5708 1.5708 0"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://mycobot_description/meshes/mycobot_320/link4.dae"/>
        </geometry>
        <origin xyz="0.0 -0.0024 -0.05" rpy="1.5708 1.5708 0"/>
      </collision>
    </link>

    <!-- wrist_2_link (link5) -->
    <link name="$(arg prefix)wrist_2_link">
      <xacro:link_inertial mass="${link5_mass}" ixx="0.00015" iyy="0.00015" izz="0.00010"/>
      <visual>
        <geometry>
          <mesh filename="package://mycobot_description/meshes/mycobot_320/link5.dae"/>
        </geometry>
        <origin xyz="0.0 0.0 -0.05" rpy="0 0 -1.5708"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://mycobot_description/meshes/mycobot_320/link5.dae"/>
        </geometry>
        <origin xyz="0.0 0.0 -0.05" rpy="0 0 -1.5708"/>
      </collision>
    </link>

    <!-- wrist_3_link (link6) -->
    <link name="$(arg prefix)wrist_3_link">
      <xacro:link_inertial mass="${link6_mass}" ixx="0.00010" iyy="0.00010" izz="0.00010"/>
      <visual>
        <geometry>
          <mesh filename="package://mycobot_description/meshes/mycobot_320/link6.dae"/>
        </geometry>
        <origin xyz="0.0 0.0 -0.0115" rpy="1.5708 1.5708 0"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://mycobot_description/meshes/mycobot_320/link6.dae"/>
        </geometry>
        <origin xyz="0.0 0.0 -0.0115" rpy="1.5708 1.5708 0"/>
      </collision>
    </link>

    <!-- ROS-Industrial flange frame -->
    <link name="$(arg prefix)flange"/>

    <!-- ROS-Industrial tool0 frame -->
    <link name="$(arg prefix)tool0"/>

    <!-- ============================================================ -->
    <!-- JOINTS - Using UR-standard names -->
    <!-- ============================================================ -->

    <!-- shoulder_pan_joint: base to shoulder -->
    <joint name="$(arg prefix)shoulder_pan_joint" type="revolute">
      <axis xyz="0 0 1"/>
      <limit effort="${joint_effort}" lower="-2.93" upper="2.93" velocity="${joint_velocity}"/>
      <parent link="$(arg prefix)base_link"/>
      <child link="$(arg prefix)shoulder_link"/>
      <origin xyz="0 0 0.1739" rpy="0 0 0"/>
      <dynamics damping="${joint_damping}" friction="${joint_friction}"/>
    </joint>

    <!-- shoulder_lift_joint: shoulder to upper_arm -->
    <joint name="$(arg prefix)shoulder_lift_joint" type="revolute">
      <axis xyz="0 0 1"/>
      <limit effort="${joint_effort}" lower="-2.35" upper="2.35" velocity="${joint_velocity}"/>
      <parent link="$(arg prefix)shoulder_link"/>
      <child link="$(arg prefix)upper_arm_link"/>
      <origin xyz="0 -0.08878 0" rpy="0 -1.5708 1.5708"/>
      <dynamics damping="${joint_damping}" friction="${joint_friction}"/>
    </joint>

    <!-- elbow_joint: upper_arm to forearm -->
    <joint name="$(arg prefix)elbow_joint" type="revolute">
      <axis xyz="0 0 1"/>
      <limit effort="${joint_effort}" lower="-2.53" upper="2.53" velocity="${joint_velocity}"/>
      <parent link="$(arg prefix)upper_arm_link"/>
      <child link="$(arg prefix)forearm_link"/>
      <origin xyz="0.135 0 -0.08878" rpy="0 0 0"/>
      <dynamics damping="${joint_damping}" friction="${joint_friction}"/>
    </joint>

    <!-- wrist_1_joint: forearm to wrist_1 -->
    <joint name="$(arg prefix)wrist_1_joint" type="revolute">
      <axis xyz="0 0 1"/>
      <limit effort="${joint_effort}" lower="-2.53" upper="2.53" velocity="${joint_velocity}"/>
      <parent link="$(arg prefix)forearm_link"/>
      <child link="$(arg prefix)wrist_1_link"/>
      <origin xyz="0.120 0 0.08878" rpy="0 0 1.5708"/>
      <dynamics damping="${joint_damping}" friction="${joint_friction}"/>
    </joint>

    <!-- wrist_2_joint: wrist_1 to wrist_2 -->
    <joint name="$(arg prefix)wrist_2_joint" type="revolute">
      <axis xyz="0 0 1"/>
      <limit effort="${joint_effort}" lower="-2.93" upper="2.93" velocity="${joint_velocity}"/>
      <parent link="$(arg prefix)wrist_1_link"/>
      <child link="$(arg prefix)wrist_2_link"/>
      <origin xyz="0 -0.095 0" rpy="1.5708 0 0"/>
      <dynamics damping="${joint_damping}" friction="${joint_friction}"/>
    </joint>

    <!-- wrist_3_joint: wrist_2 to wrist_3 -->
    <joint name="$(arg prefix)wrist_3_joint" type="revolute">
      <axis xyz="0 0 1"/>
      <limit effort="${joint_effort}" lower="-3.14" upper="3.14" velocity="${joint_velocity}"/>
      <parent link="$(arg prefix)wrist_2_link"/>
      <child link="$(arg prefix)wrist_3_link"/>
      <origin xyz="0 0.0655 0" rpy="-1.5708 0 0"/>
      <dynamics damping="${joint_damping}" friction="${joint_friction}"/>
    </joint>

    <!-- wrist_3-flange fixed joint -->
    <joint name="$(arg prefix)wrist_3-flange" type="fixed">
      <parent link="$(arg prefix)wrist_3_link"/>
      <child link="$(arg prefix)flange"/>
      <origin xyz="0 0 0" rpy="0 ${-pi/2.0} ${-pi/2.0}"/>
    </joint>

    <!-- flange-tool0 fixed joint -->
    <joint name="$(arg prefix)flange-tool0" type="fixed">
      <parent link="$(arg prefix)flange"/>
      <child link="$(arg prefix)tool0"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <!-- Gazebo Sim ROS2 Control Plugin -->
    <xacro:include filename="$(find mycobot_description)/urdf/control/gazebo_sim_ros2_control.urdf.xacro"/>
    <xacro:load_gazebo_sim_ros2_control_plugin
      robot_name="$(arg robot_name)"
      use_gazebo="$(arg use_gazebo)"
      controllers_file="$(arg controllers_file)"/>

    <!-- Include Soft End Effector -->
    <xacro:include filename="$(find mycobot_description)/urdf/mech/soft_end_effector.urdf.xacro"/>

    <!-- Conditionally add soft end effector -->
    <xacro:if value="$(arg use_soft_ee)">
      <xacro:soft_end_effector parent_link="$(arg prefix)wrist_3_link" prefix="$(arg prefix)"/>
    </xacro:if>

    <!-- UR-compatible ROS2 Control Configuration -->
    <xacro:include filename="$(find mycobot_description)/urdf/control/mycobot_320_ur_ros2_control.urdf.xacro"/>
    <xacro:mycobot_320_ur_ros2_control
      prefix="$(arg prefix)"
      use_gazebo="$(arg use_gazebo)"/>

</robot>
